{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "研墨",
  "version": "0.4.2",
  "identifier": "com.scholar-assistant.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && node scripts/build-python.cjs",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "研墨",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:; connect-src 'self' http://localhost:18088 http://127.0.0.1:18088; img-src 'self' data: blob: asset: https://asset.localhost http://localhost:18088 http://127.0.0.1:18088; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self';",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$PICTURE/**",
            "$VIDEO/**",
            "$DOWNLOAD/**",
            "$DESKTOP/**",
            "$DOCUMENT/**",
            "$HOME/**"
          ]
        }
      },
      "dangerousDisableAssetCspModification": false
    }
  },
  "plugins": {
    "shell": {
      "open": "^((mailto:\\w+)|(tel:\\w+)|(https?://\\w+)).+|^[A-Za-z]:.+|^/.+"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "python-dist",
      "WebView2Loader.dll"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"]
      },
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    }
  }
}
